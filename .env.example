# API
INTERVIU_DB_BACKEND=sqlite
INTERVIU_DB_PATH=apps/api/data/interviu.db
INTERVIU_ENV=development
INTERVIU_API_KEYS=
INTERVIU_CORS_ORIGINS=
INTERVIU_RATE_LIMIT_ENABLED=1
# Keep private/internal HTTP candidate endpoints disabled unless you are running
# a trusted local-only harness and understand the SSRF risk.
INTERVIU_HTTP_CANDIDATE_ALLOW_PRIVATE=0
# TraceRazor audit controls. Interviu stores every span, then sends a bounded
# candidate-only slice to the local TraceRazor binary so demos stay responsive.
INTERVIU_TRACERAZOR_TIMEOUT_S=30
INTERVIU_TRACERAZOR_MAX_STEPS=8

# Agent Refinery OpenAI research (server-side only; never use NEXT_PUBLIC_*).
# Any of these names is accepted: OPENAI_API_KEY, OPENAI_KEY, openai_key
OPENAI_API_KEY=
# Force deterministic demo mode even if a local env file contains an OpenAI key.
INTERVIU_DISABLE_OPENAI=0
# Optional model overrides
# INTERVIU_OPENAI_MODEL=gpt-4.1
# INTERVIU_OPENAI_DEEP_MODEL=o4-mini-deep-research
# INTERVIU_OPENAI_TIMEOUT_S=300

# Set these to use Supabase instead of SQLite.
# Use a server-only service role or secret key. Never expose it through NEXT_PUBLIC_*.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
