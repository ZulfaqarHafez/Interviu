# API
ASSAY_DB_BACKEND=sqlite
ASSAY_DB_PATH=apps/api/data/assay.db
ASSAY_ENV=development
ASSAY_API_KEYS=
# Hosted multi-tenant mode. Leave off locally; when enabled, non-health routes
# require X-API-Key plus X-Assay-Tenant and stored artifacts are tenant scoped.
ASSAY_REQUIRE_TENANT=0
ASSAY_DEFAULT_TENANT=local
ASSAY_CORS_ORIGINS=
ASSAY_RATE_LIMIT_ENABLED=1
# Keep private/internal HTTP candidate endpoints disabled unless you are running
# a trusted local-only harness and understand the SSRF risk.
ASSAY_HTTP_CANDIDATE_ALLOW_PRIVATE=0
# TraceRazor audit controls. Assay stores every span, then sends a bounded
# candidate-only slice to the local TraceRazor binary so demos stay responsive.
ASSAY_TRACERAZOR_TIMEOUT_S=30
ASSAY_TRACERAZOR_MAX_STEPS=8

# Agent Refinery OpenAI research (server-side only; never use NEXT_PUBLIC_*).
# Any of these names is accepted: OPENAI_API_KEY, OPENAI_KEY, openai_key
OPENAI_API_KEY=
# Force deterministic demo mode even if a local env file contains an OpenAI key.
ASSAY_DISABLE_OPENAI=0
# Optional semantic judge fallback for paraphrase rescue. Deterministic scoring
# remains the default/source of truth when this is off.
ASSAY_LLM_JUDGE_ENABLED=0
ASSAY_LLM_JUDGE_MODEL=gpt-4.1
ASSAY_LLM_JUDGE_MIN_CONFIDENCE=0.72
# Qualify the judge: research what the agent should be (from its agent.md, with
# optional web search) and build a tailored exam + rubric before grading. Off by
# default; degrades to the static pack + keyword grading with no OpenAI key.
ASSAY_TAILORED_EXAMS_ENABLED=0
# fast (one grounded call) or deep (adds web search + cited sources).
ASSAY_QUALIFY_MODE=fast
# ASSAY_QUALIFY_TIMEOUT_S=90
# Max generated probes per run (ceiling 8).
ASSAY_TAILORED_MAX_ITEMS=5
# LLM-judge-as-primary grading against the tailored rubric (vs keyword fallback).
ASSAY_TAILORED_JUDGE_ENABLED=0
# ASSAY_TAILORED_JUDGE_MODEL=gpt-4.1
# Optional model overrides
# ASSAY_OPENAI_MODEL=gpt-4.1
# ASSAY_OPENAI_DEEP_MODEL=o4-mini-deep-research
# ASSAY_OPENAI_TIMEOUT_S=300

# Set these to use Supabase instead of SQLite.
# Use a server-only service role or secret key. Never expose it through NEXT_PUBLIC_*.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
